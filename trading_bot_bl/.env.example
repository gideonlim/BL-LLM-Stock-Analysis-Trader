# Alpaca API credentials
# Get these from https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=APIKEY
ALPACA_API_SECRET=APISECRET
ALPACA_PAPER=true          # "true" for paper trading, "false" for live

# Risk limits
MAX_EXPOSURE_PCT=80.0      # Max % of equity deployed in positions
MAX_POSITION_PCT=10.0      # Max % of equity in any single stock
DAILY_LOSS_LIMIT_PCT=3.0   # Stop trading if portfolio drops this % today

# Position limits
MAX_POSITIONS=10           # Max concurrent positions (existing + new)
MIN_POSITION_PCT=2.0       # Skip orders below this % of equity (too small to matter)

# Signal quality filters
MIN_COMPOSITE_SCORE=15.0   # Minimum backtest composite score to trade
MIN_BACKTEST_TRADES=3      # Minimum OOS trades for signal reliability
MIN_CONFIDENCE_SCORE=2     # Minimum confidence score (0-6)
MAX_PBO=0.50               # Max probability of backtest overfitting (0-1, 1.0 = disable)

# Earnings blackout (blocks entries near earnings announcements)
EARNINGS_BLACKOUT_ENABLED=true   # "true" to block entries near earnings
EARNINGS_BLACKOUT_PRE_DAYS=3     # Days before earnings to block
EARNINGS_BLACKOUT_POST_DAYS=1    # Days after earnings to block

# ADV liquidity filter (blocks entries in illiquid stocks)
ADV_LIQUIDITY_ENABLED=true        # "true" to block illiquid entries
MIN_ADV_SHARES=500000             # Minimum avg daily volume in shares
MIN_ADV_DOLLAR_VOLUME=5000000     # Minimum avg daily dollar volume
MAX_ADV_PARTICIPATION_PCT=1.0     # Max position as % of daily dollar volume

# Paths
SIGNALS_DIR=signals        # Where quant_analysis_bot writes signals

# Execution
DRY_RUN=false              # "true" to log without submitting orders
HISTORY_LOOKBACK_DAYS=30   # Days of execution history to consider
MAX_ENTRY_SLIPPAGE_PCT=1.0 # Max % above live price for limit entry (0 = market order)
MAX_SIGNAL_DRIFT_PCT=3.0   # Max % drift between signal price and live price (0 = disabled)

# Black-Litterman optimization
USE_BLACK_LITTERMAN=true   # "true" to use BL, "false" for marginal Sharpe
BL_TAU=0.05                # Prior uncertainty scalar (0.01-0.1)
BL_LOOKBACK_DAYS=60        # Days of return history for covariance
BL_REGIME_SENSITIVE=true   # Blend EWMA + Ledoit-Wolf based on vol regime
BL_MAX_SECTOR_PCT=0.40     # Max 40% in any single GICS sector (1.0 = disable)

# Market sentiment (VIX + put/call regime-based position sizing)
MARKET_SENTIMENT_ENABLED=true
SENTIMENT_FEAR_VIX=30.0    # VIX above this → fear (industry standard: 30+)
SENTIMENT_GREED_VIX=15.0   # VIX below this → greed
SENTIMENT_FEAR_PC=1.2      # Put/call ratio above this → fear (top ~5% of days)
SENTIMENT_GREED_PC=0.6     # Put/call ratio below this → greed
SENTIMENT_FEAR_SIZE_MULT=1.10  # Size boost during extreme fear (contrarian)
SENTIMENT_GREED_SIZE_MULT=0.90 # Size cut during extreme greed (defensive)

# SPY trend regime (bear market filter — separate from VIX contrarian)
SPY_REGIME_ENABLED=true               # "true" to enable SPY 200-SMA bear filter
SPY_BEAR_CONFIRMATION_DAYS=3          # Days below 200-SMA to confirm BEAR
SPY_BEAR_MAX_POSITIONS=5              # Max positions during BEAR regime
SPY_BEAR_MIN_COMPOSITE_SCORE=30.0     # Min composite score during BEAR
SPY_CAUTION_MAX_POSITIONS=6           # Max positions during CAUTION regime
SPY_CAUTION_MIN_COMPOSITE_SCORE=22.0  # Min composite score during CAUTION
SPY_SEVERE_DRAWDOWN_PCT=15.0          # Drawdown from 52w high → halt new entries

# Oil spike → fertilizer boost (event-driven overlay)
# When USO posts a 10%+ weekly gain, temporarily boosts composite scores
# for fertilizer tickers.  Backed by 10yr event study (MOS +6.3% / 79% WR).
OIL_SPIKE_ENABLED=false           # "true" to enable (dry-run first!)
OIL_SPIKE_BOOST=8.0               # Peak composite-score boost (decays linearly)
OIL_SPIKE_WINDOW_DAYS=20          # Days over which boost decays to 0
OIL_SPIKE_THRESHOLD=0.10          # Min 5-day USO return to trigger (0.10 = 10%)
OIL_SPIKE_TICKERS=MOS,CF          # Tier 1: fertilizers (immediate boost, 20d decay)

# Tier 2: Airlines — mean-reversion trade after oil spikes.
# Airlines dip 1-3 days then snap back.  Delayed entry on day 3.
# Backed by 21-event study: +1.87% excess vs SPY, 71% WR, t=2.21.
OIL_SPIKE_AIRLINE_TICKERS=UAL,DAL # Tier 2 tickers (comma-separated)
OIL_SPIKE_AIRLINE_BOOST=5.0       # Peak boost for airlines (smaller than tier 1)
OIL_SPIKE_AIRLINE_DELAY_DAYS=3    # Don't apply boost until day N after spike
OIL_SPIKE_AIRLINE_DECAY_DAYS=10   # Boost decays to 0 over this many days after delay

# Ticker cooldown (prevents churn — applies after both buys and sells)
TICKER_COOLDOWN_DAYS=2     # Days to wait before re-trading a ticker

# FinBERT news sentiment (headlines scored via ProsusAI/finBERT)
FINBERT_ENABLED=true            # "true" to enable FinBERT headline scoring
FINBERT_SCORE_WEIGHT=5.0        # Max composite-score adjustment (±points)
FINBERT_MAX_HEADLINES=5          # Headlines per ticker to score

# CPPI drawdown control (smooth position scaling on drawdown)
CPPI_ENABLED=false                 # "true" to enable CPPI exposure scaling
CPPI_MAX_DRAWDOWN_PCT=10.0        # Floor = peak * (1 - this%). Exposure → 0 at floor
CPPI_MULTIPLIER=5                  # Risk multiplier (higher = exposure stays full longer)
CPPI_MIN_EXPOSURE_PCT=10.0        # Minimum exposure even at the floor (prevents cash lock)

# LLM views (scenario-conditioned return predictions via Claude)
LLM_VIEWS_ENABLED=true     # "true" to enable LLM-enhanced views
LLM_PROVIDER=anthropic     # "anthropic" or "openai"
LLM_MODEL=claude-haiku-4-5-20251001
LLM_NUM_SAMPLES=5          # One per scenario (bull/bear/base/stress/momentum)
LLM_MAX_TICKERS=10         # Only query top-N tickers by confidence
LLM_TEMPERATURE=0.7        # Sampling temperature (needs > 0 for variance)
LLM_WEIGHT=0.3             # Blend weight for LLM views (0-1)
ANTHROPIC_API_KEY=          # Get from https://console.anthropic.com
