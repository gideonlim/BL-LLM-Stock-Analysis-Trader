# Alpaca API credentials
# Get these from https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=APIKEY
ALPACA_API_SECRET=APISECRET
ALPACA_PAPER=true          # "true" for paper trading, "false" for live

# Risk limits
MAX_EXPOSURE_PCT=80.0      # Max % of equity deployed in positions
MAX_POSITION_PCT=12.0      # Max % of equity in any single stock
DAILY_LOSS_LIMIT_PCT=3.0   # Stop trading if portfolio drops this % today

# Position limits
MAX_POSITIONS=8            # Max concurrent positions (existing + new)
MIN_POSITION_PCT=2.0       # Skip orders below this % of equity (too small to matter)

# Signal quality filters
MIN_COMPOSITE_SCORE=20.0   # Minimum backtest composite score to trade
MIN_CONFIDENCE_SCORE=2     # Minimum confidence score (0-6)

# Paths
SIGNALS_DIR=signals        # Where quant_analysis_bot writes signals

# Execution
DRY_RUN=false              # "true" to log without submitting orders
MAX_ENTRY_SLIPPAGE_PCT=1.5 # Max % above live price for limit entry (0 = market order)

# Black-Litterman optimization
USE_BLACK_LITTERMAN=true   # "true" to use BL, "false" for marginal Sharpe
BL_TAU=0.05                # Prior uncertainty scalar (0.01-0.1)
BL_LOOKBACK_DAYS=60        # Days of return history for covariance

# LLM views (optional — bot works fine without this)
LLM_VIEWS_ENABLED=false    # "true" to enable LLM-enhanced views
LLM_PROVIDER=anthropic     # "anthropic" or "openai"
LLM_MODEL=claude-haiku-4-5-20251001
LLM_NUM_SAMPLES=10         # Repeated predictions per ticker
LLM_MAX_TICKERS=10         # Only query top-N tickers by confidence
LLM_TEMPERATURE=0.7        # Sampling temperature (needs > 0 for variance)
LLM_WEIGHT=0.3             # Blend weight for LLM views (0-1)
ANTHROPIC_API_KEY=          # Get from https://console.anthropic.com
